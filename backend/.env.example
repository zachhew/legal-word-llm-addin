# Do not put LLM API keys here.
# API keys are entered by the user in the add-in UI and are not stored by the backend.

APP_ENV=development
APP_NAME=Legal Word LLM Assistant
APP_VERSION=0.1.0
LOG_LEVEL=INFO

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

CORS_ORIGINS=https://localhost:3000,http://localhost:3000,https://127.0.0.1:3000,http://127.0.0.1:3000

DEFAULT_PROVIDER=openrouter
DEFAULT_MODEL=qwen/qwen3.5-flash-02-23
RECOMMENDED_OPENROUTER_MODEL=qwen/qwen3-235b-a22b-thinking-2507

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_COMPATIBLE_BASE_URL=

LLM_REQUEST_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.2
LLM_JSON_REPAIR_ATTEMPTS=1

MAX_FULL_CONTEXT_CHARS=30000
MAX_CONTEXT_CHARS=18000
CHUNK_TARGET_CHARS=2500
CHUNK_OVERLAP_CHARS=300
TOP_K_CHUNKS=6
